# Notification System Configuration Template

# ============================================
# EMAIL NOTIFICATIONS
# ============================================
SHOP_OWNER_EMAIL=admin@restaurant.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@restaurant.com

# ============================================
# SMS/WHATSAPP/VOICE NOTIFICATIONS (Twilio)
# ============================================
# Get these from https://www.twilio.com/
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token

# For SMS notifications
TWILIO_PHONE_NUMBER=+1234567890

# For WhatsApp notifications
TWILIO_WHATSAPP_NUMBER=+1234567890

# ============================================
# NOTIFICATION FEATURE FLAGS
# ============================================
ENABLE_SMS_NOTIFICATIONS=False
ENABLE_WHATSAPP_NOTIFICATIONS=False
ENABLE_VOICE_NOTIFICATIONS=False
ENABLE_EMAIL_NOTIFICATIONS=True

# Retry settings for failed notifications
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY_SECONDS=5

